# =============================================================================
# netorch .gitignore
# Keeps secrets, credentials, and runtime artifacts off GitHub
# =============================================================================

# --- Credentials & secrets (NEVER commit these) ---
inventory.ini
netorch.toml
*.toml
*.ini
*.env
.env*
# secrets/ Python module — tracked
# but ignore any credential or token files inside it
secrets/*.json
secrets/*.key
secrets/*.env
creds/

# --- Logs ---
logs/
*.log
*.log.*

# --- Job persistence / runtime state ---
jobs/
job_store*.json
*.json.bak

# --- Python bytecode ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# --- Virtual environment ---
venv/
.venv/
env/
ENV/

# --- Pytest / test artifacts ---
.pytest_cache/
.coverage
htmlcov/
*.xml

# --- Editor / OS noise ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Distribution / build ---
dist/
build/
*.egg-info/

# --- SQLite / database runtime files (DB migrated to PostgreSQL) ---
*.db
*.db-shm
*.db-wal

# --- RPM build artifacts ---
*.rpm

# --- Session / export files ---
session_export.txt

# --- Per-instance operator files (not for repo) ---
# These are created/edited per deployment — not source-controlled
workflows/
runbooks/

# --- Claude Code / AI assistant files (machine-local, not for repo) ---
.claude/
CLAUDE.md
