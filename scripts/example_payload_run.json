{
  "_comment": "Run job targeting an entire group — exec-mode commands plus config-mode commands",

  "job_id": "run-example-001",
  "mode": "run",
  "devices": [
    {
      "group": "core_switches"
    }
  ],
  "commands": [
    "show running-config | include ntp"
  ],
  "config_mode_commands": [
    "ntp server 10.0.0.1",
    "ntp server 10.0.0.2",
    "logging host 10.0.0.50"
  ],
  "options": {
    "timeout_per_device": 30,
    "max_workers": 20,
    "backup_config_before_change": true
  }
}
